<!DOCTYPE html>
<html>
<head>
    <title>System Health Monitor</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            text-align: center;
            padding: 20px;
        }
        .card {
            background: white;
            padding: 20px;
            margin: 10px auto;
            width: 300px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        h2 { color: #333; }
    </style>
</head>
<body>
    <h1>🖥 System Health Monitor</h1>
    <div class="card">
        <h2>CPU Usage</h2>
        <p>{{ info.cpu_usage }}%</p>
    </div>
    <div class="card">
        <h2>Memory Usage</h2>
        <p>{{ info.memory_usage }}%</p>
    </div>
    <div class="card">
        <h2>Disk Usage</h2>
        <p>{{ info.disk_usage }}%</p>
    </div>
    <div class="card">
        <h2>System Info</h2>
        <p>{{ info.platform }} ({{ info.architecture }})</p>
        <p>{{ info.platform_version }}</p>
        <p>Time: {{ info.time }}</p>
    </div>
</body>
</html>
